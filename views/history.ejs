<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>bambisleep.chat - Vote for History</title>
    <meta name="description" content="Vote On bambisleep.chat history">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
</head>
<body>
    <script type="module" src="mjs/main.mjs"></script>
    <h1>Chat History</h1>
    <ul>
        <% chatHistory.forEach((entry, index) => { %>
            <li>
                <strong><%= entry.role %>:</strong> <%= entry.content %> (Votes: <%= entry.votes %>)
                <button onclick="vote(<%= index %>, 'up')">👍</button>
                <button onclick="vote(<%= index %>, 'down')">👎</button>
                <span>Votes: <%= entry.votes %></span>
            </li>
        <% }); %>
    </ul>
    <script>
        function vote(index, type) {
            fetch(`/vote/${index}/${type}`, { method: 'POST' })
                .then(response => response.json())
                .then(data => {
                    // Update the UI with the new vote count
                    document.querySelectorAll('li')[index].querySelector('span').innerText = `Votes: ${data.votes}`;
                })
                .catch(error => console.error('Error:', error));
        }
    </script>
</body>
</html>