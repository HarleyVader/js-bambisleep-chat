<!DOCTYPE html>
<html lang="en">
<%- include('../views/partials/head.ejs') %>
<title>BambiSleep.Chat - Profile</title>

<body data-username="<%= profile ? profile.username : '' %>">
  <%- include('../views/partials/nav.ejs') %>

  <div class="profile-container">
    <div class="profile-header">
      <% if (profile) { %>
        <h1><%= profile.username %>'s Profile</h1>
        <div class="profile-stats">
          <div class="level-badge">Level <%= profile.level || 0 %></div>
          <div class="xp-progress">
            <div class="xp-progress-bar">
              <div class="xp-progress-fill" style="width: <%= profile.percentToNextLevel || 0 %>%"></div>
            </div>
            <div class="xp-label"><%= profile.currentXp || 0 %> / <%= profile.xpForNextLevel || 100 %> XP</div>
          </div>
          <div class="date-joined">Joined: <%= profile.dateJoined ? new Date(profile.dateJoined).toLocaleDateString() : 'Unknown' %></div>
        </div>
      <% } else { %>
        <h1>Profile Not Found</h1>
      <% } %>
    </div>

    <% if (profile) { %>
      <div class="profile-content">
        <div class="profile-sections">
          <div class="profile-section triggers-section">
            <h2>Triggers</h2>
            <div class="trigger-list" id="trigger-list">
              <% if (profile.triggers && profile.triggers.length > 0) { %>
                <% profile.triggers.forEach(function(trigger) { %>
                  <div class="trigger-item" data-trigger="<%= trigger %>"><%= trigger %></div>
                <% }); %>
              <% } else { %>
                <p>No triggers saved</p>
              <% } %>
            </div>
          </div>

          <div class="profile-section achievements-section">
            <h2>Achievements</h2>
            <div class="achievement-list">
              <% if (profile.achievements && profile.achievements.length > 0) { %>
                <% profile.achievements.forEach(function(achievement) { %>
                  <div class="achievement-item">
                    <span class="achievement-icon"><%= achievement.icon %></span>
                    <span class="achievement-name"><%= achievement.name %></span>
                    <span class="achievement-date"><%= new Date(achievement.date).toLocaleDateString() %></span>
                  </div>
                <% }); %>
              <% } else { %>
                <p>No achievements yet</p>
              <% } %>
            </div>
          </div>

          <div class="profile-section sessions-section">
            <h2>Saved Sessions</h2>
            <div class="session-list" id="session-list">
              <% if (profile.sessions && profile.sessions.length > 0) { %>
                <% profile.sessions.forEach(function(session) { %>
                  <div class="session-item">
                    <span class="session-name"><%= session.name %></span>
                    <span class="session-date"><%= new Date(session.createdAt).toLocaleDateString() %></span>
                    <% if (isOwnProfile) { %>
                      <button class="load-session-btn" data-session-id="<%= session.id %>">Load</button>
                    <% } %>
                  </div>
                <% }); %>
              <% } else { %>
                <p>No saved sessions</p>
              <% } %>
            </div>
          </div>
        </div>

        <% if (isOwnProfile) { %>
          <div class="profile-controls">
            <h2>Profile Settings</h2>
            <div class="settings-panel">
              <div class="settings-group">
                <h3>Account</h3>
                <div class="setting-item">
                  <label for="profile-visibility">Profile Visibility</label>
                  <select id="profile-visibility" data-setting="profileVisibility">
                    <option value="public" <%= profile.settings && profile.settings.profileVisibility === 'public' ? 'selected' : '' %>>Public</option>
                    <option value="friends" <%= profile.settings && profile.settings.profileVisibility === 'friends' ? 'selected' : '' %>>Friends Only</option>
                    <option value="private" <%= profile.settings && profile.settings.profileVisibility === 'private' ? 'selected' : '' %>>Private</option>
                  </select>
                </div>
                <div class="setting-item">
                  <label for="session-sharing">Session Sharing</label>
                  <select id="session-sharing" data-setting="sessionSharing" data-level-required="5">
                    <option value="public" <%= profile.settings && profile.settings.sessionSharing === 'public' ? 'selected' : '' %>>Public</option>
                    <option value="friends" <%= profile.settings && profile.settings.sessionSharing === 'friends' ? 'selected' : '' %>>Friends Only</option>
                    <option value="private" <%= profile.settings && profile.settings.sessionSharing === 'private' ? 'selected' : '' %>>Private</option>
                  </select>
                </div>
              </div>
              
              <div class="settings-group">
                <h3>Notification Preferences</h3>
                <div class="setting-item">
                  <label for="xp-notifications">XP Notifications</label>
                  <input type="checkbox" id="xp-notifications" data-setting="xpNotifications" <%= profile.settings && profile.settings.xpNotifications ? 'checked' : '' %>>
                </div>
                <div class="setting-item">
                  <label for="achievement-notifications">Achievement Notifications</label>
                  <input type="checkbox" id="achievement-notifications" data-setting="achievementNotifications" <%= profile.settings && profile.settings.achievementNotifications ? 'checked' : '' %>>
                </div>
              </div>
              
              <div class="settings-actions">
                <button id="save-profile-settings" class="primary-button">Save Settings</button>
                <button id="reset-profile-settings" class="secondary-button">Reset</button>
              </div>
            </div>
          </div>
        <% } %>
      </div>
    <% } %>
  </div>

  <%- include('../views/partials/footer.ejs') %>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // Set up session loading functionality
      const sessionButtons = document.querySelectorAll('.load-session-btn');
      sessionButtons.forEach(button => {
        button.addEventListener('click', () => {
          const sessionId = button.getAttribute('data-session-id');
          if (sessionId && window.bambiSessions) {
            window.bambiSessions.loadSession(sessionId);
            
            // Flash button to indicate loading
            button.textContent = 'Loading...';
            button.disabled = true;
            
            setTimeout(() => {
              button.textContent = 'Load';
              button.disabled = false;
            }, 2000);
          }
        });
      });
      
      // Set up trigger activation
      const triggerItems = document.querySelectorAll('.trigger-item');
      triggerItems.forEach(item => {
        item.addEventListener('click', () => {
          const triggerName = item.getAttribute('data-trigger');
          if (triggerName && window.socket && window.socket.connected) {
            window.socket.emit('client-trigger-activate', {
              triggerName,
              timestamp: Date.now()
            });
            
            // Visual feedback
            item.classList.add('active');
            setTimeout(() => {
              item.classList.remove('active');
            }, 1000);
          }
        });
      });
      
      // Handle profile settings
      const saveSettingsBtn = document.getElementById('save-profile-settings');
      if (saveSettingsBtn) {
        saveSettingsBtn.addEventListener('click', () => {
          try {
            const settings = collectProfileSettings();
            
            if (window.socket && window.socket.connected) {
              window.socket.emit('client-save-profile-settings', settings);
              
              // Show visual feedback
              saveSettingsBtn.textContent = 'Saving...';
              saveSettingsBtn.disabled = true;
              
              // Listen for response
              window.socket.once('server-profile-settings-saved', () => {
                saveSettingsBtn.textContent = 'Settings Saved!';
                setTimeout(() => {
                  saveSettingsBtn.textContent = 'Save Settings';
                  saveSettingsBtn.disabled = false;
                }, 2000);
                
                // Award XP for updating profile
                if (window.socket && window.socket.connected) {
                  window.socket.emit('client-award-xp', {
                    action: 'profile_update',
                    amount: 5,
                    timestamp: Date.now()
                  });
                }
              });
            }
          } catch (error) {
            console.error('Error saving profile settings:', error);
            saveSettingsBtn.textContent = 'Error Saving';
            setTimeout(() => {
              saveSettingsBtn.textContent = 'Save Settings';
              saveSettingsBtn.disabled = false;
            }, 2000);
          }
        });
      }
      
      // Reset profile settings
      const resetSettingsBtn = document.getElementById('reset-profile-settings');
      if (resetSettingsBtn) {
        resetSettingsBtn.addEventListener('click', () => {
          // Get all settings inputs
          const settingsInputs = document.querySelectorAll('[data-setting]');
          settingsInputs.forEach(input => {
            if (input.type === 'checkbox') {
              input.checked = input.hasAttribute('data-default-checked');
            } else if (input.tagName === 'SELECT') {
              const defaultValue = input.getAttribute('data-default-value');
              if (defaultValue) {
                input.value = defaultValue;
              } else {
                input.selectedIndex = 0;
              }
            } else {
              input.value = input.getAttribute('data-default-value') || '';
            }
          });
          
          // Visual feedback
          resetSettingsBtn.textContent = 'Reset!';
          setTimeout(() => {
            resetSettingsBtn.textContent = 'Reset';
          }, 1000);
        });
      }
      
      // Check for level-locked features
      updateFeatureAvailability(parseInt('<%= profile ? profile.level : 0 %>'));
      
      // Helper functions
      function collectProfileSettings() {
        const settings = {};
        const settingsInputs = document.querySelectorAll('[data-setting]');
        
        settingsInputs.forEach(input => {
          const settingName = input.getAttribute('data-setting');
          if (!settingName) return;
          
          if (input.type === 'checkbox') {
            settings[settingName] = input.checked;
          } else if (input.tagName === 'SELECT') {
            settings[settingName] = input.value;
          } else {
            settings[settingName] = input.value;
          }
        });
        
        return settings;
      }
      
      function updateFeatureAvailability(level) {
        document.querySelectorAll('[data-level-required]').forEach(el => {
          const requiredLevel = parseInt(el.getAttribute('data-level-required'));
          if (level >= requiredLevel) {
            el.classList.remove('locked');
            el.disabled = false;
            
            // Remove any existing tooltip
            const tooltip = el.parentElement.querySelector('.level-lock-tooltip');
            if (tooltip) tooltip.remove();
          } else {
            el.classList.add('locked');
            el.disabled = true;
            
            // Add tooltip if not already present
            if (!el.parentElement.querySelector('.level-lock-tooltip')) {
              const tooltip = document.createElement('div');
              tooltip.className = 'level-lock-tooltip';
              tooltip.textContent = `Unlocks at level ${requiredLevel}`;
              el.parentElement.appendChild(tooltip);
            }
          }
        });
      }
    });
  </script>
</body>
</html>