<!DOCTYPE html>
<html lang="en">
<%- include('../views/partials/head.ejs') %>
<title>BambiSleep.Chat - Profile</title>

<body data-username="<%= profile ? profile.username : '' %>">
  <%- include('../views/partials/nav.ejs') %>

  <div class="profile-container">
    <div class="profile-header">
      <% if (profile) { %>
        <h1><%= profile.username %>'s Profile</h1>
        <div class="profile-stats">
          <div class="level-badge">Level <%= profile.level || 0 %></div>
          <div class="xp-progress">
            <div class="xp-progress-bar">
              <div class="xp-progress-fill" style="width: <%= profile.percentToNextLevel || 0 %>%"></div>
            </div>
            <div class="xp-label"><%= profile.currentXp || 0 %> / <%= profile.xpForNextLevel || 100 %> XP</div>
          </div>
          <div class="date-joined">Joined: <%= profile.dateJoined ? new Date(profile.dateJoined).toLocaleDateString() : 'Unknown' %></div>
        </div>
      <% } else { %>
        <h1>Profile Not Found</h1>
      <% } %>
    </div>

    <% if (profile) { %>
      <div class="profile-content">
        <div class="profile-sections">
          <div class="profile-section triggers-section">
            <h2>Triggers</h2>
            <div class="trigger-list" id="trigger-list">
              <% if (profile.triggers && profile.triggers.length > 0) { %>
                <% profile.triggers.forEach(function(trigger) { %>
                  <div class="trigger-item" data-trigger="<%= trigger %>"><%= trigger %></div>
                <% }); %>
              <% } else { %>
                <p>No triggers saved</p>
              <% } %>
            </div>
          </div>

          <div class="profile-section achievements-section">
            <h2>Achievements</h2>
            <div class="achievement-list">
              <% if (profile.achievements && profile.achievements.length > 0) { %>
                <% profile.achievements.forEach(function(achievement) { %>
                  <div class="achievement-item">
                    <span class="achievement-icon"><%= achievement.icon %></span>
                    <span class="achievement-name"><%= achievement.name %></span>
                    <span class="achievement-date"><%= new Date(achievement.date).toLocaleDateString() %></span>
                  </div>
                <% }); %>
              <% } else { %>
                <p>No achievements yet</p>
              <% } %>
            </div>
          </div>

          <div class="profile-section sessions-section">
            <h2>Saved Sessions</h2>
            <div class="session-list" id="session-list">
              <% if (profile.sessions && profile.sessions.length > 0) { %>
                <% profile.sessions.forEach(function(session) { %>
                  <div class="session-item">
                    <span class="session-name"><%= session.name %></span>
                    <span class="session-date"><%= new Date(session.createdAt).toLocaleDateString() %></span>
                    <% if (isOwnProfile) { %>
                      <button class="load-session-btn" data-session-id="<%= session.id %>">Load</button>
                    <% } %>
                  </div>
                <% }); %>
              <% } else { %>
                <p>No saved sessions</p>
              <% } %>
            </div>
          </div>
        </div>

        <% if (isOwnProfile) { %>
          <div class="profile-controls">
            <h2>Profile Settings</h2>
            <%- include('../views/partials/profile-system-controls.ejs') %>
          </div>
        <% } %>
      </div>
    <% } %>
  </div>

  <%- include('../views/partials/footer.ejs') %>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // Set up session loading functionality
      const sessionButtons = document.querySelectorAll('.load-session-btn');
      sessionButtons.forEach(button => {
        button.addEventListener('click', () => {
          const sessionId = button.getAttribute('data-session-id');
          if (sessionId && window.bambiSessions) {
            window.bambiSessions.loadSession(sessionId);
            
            // Flash button to indicate loading
            button.textContent = 'Loading...';
            button.disabled = true;
            
            setTimeout(() => {
              button.textContent = 'Load';
              button.disabled = false;
            }, 2000);
          }
        });
      });
      
      // Set up trigger activation
      const triggerItems = document.querySelectorAll('.trigger-item');
      triggerItems.forEach(item => {
        item.addEventListener('click', () => {
          const triggerName = item.getAttribute('data-trigger');
          if (triggerName && window.socket && window.socket.connected) {
            window.socket.emit('client-trigger-activate', {
              triggerName,
              timestamp: Date.now()
            });
            
            // Visual feedback
            item.classList.add('active');
            setTimeout(() => {
              item.classList.remove('active');
            }, 1000);
          }
        });
      });
    });
  </script>
</body>
</html>