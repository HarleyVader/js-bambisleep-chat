<nav>
  <ul>
    <li><a href="/">BambiSleep.Chat</a></li>
    <li><a href="/trigger-script" class="nav-link">Triggers</a></li>
    <li><a href="/scrapers">Scrapers</a></li>
    <li><a href="/help">Help</a></li>
    <li><a href="/profile">Profiles</a></li>
    <% if (locals.username) { %>
      <li><a href="/sessions/dashboard">My Sessions</a></li>
    <% } %>
  </ul>
  
  <div class="nav-user-info">
    <% if (locals.username) { %>
      <span class="username"><%= locals.username %></span>
      <div class="user-level-indicator" id="nav-level-indicator">
        <% if (locals.userLevel !== undefined) { %>
          Level <%= locals.userLevel %>
        <% } %>
      </div>
    <% } %>
  </div>
</nav>

<% if (locals.username && locals.path && locals.path.startsWith('/sessions')) { %>
  <nav class="subnav sessions-nav">
    <ul>
      <li><a href="/sessions/dashboard" class="<%= locals.path === '/sessions/dashboard' ? 'active' : '' %>">
        <i class="fas fa-th-large"></i> Dashboard
      </a></li>
      <li><a href="/sessions" class="<%= locals.path === '/sessions' ? 'active' : '' %>">
        <i class="fas fa-list"></i> All Sessions
      </a></li>
      <li><a href="/sessions/dashboard?visibility=public" class="<%= locals.path === '/sessions/dashboard' && locals.query && locals.query.visibility === 'public' ? 'active' : '' %>">
        <i class="fas fa-globe"></i> Public Sessions
      </a></li>
      <li><a href="/sessions/dashboard?sortBy=most_likes" class="<%= locals.path === '/sessions/dashboard' && locals.query && locals.query.sortBy === 'most_likes' ? 'active' : '' %>">
        <i class="fas fa-thumbs-up"></i> Most Liked
      </a></li>
    </ul>
  </nav>
<% } %>

<script>
  // Update nav bar level indicator when user level changes
  document.addEventListener('level-changed', function(event) {
    const levelIndicator = document.getElementById('nav-level-indicator');
    if (levelIndicator && event.detail && event.detail.level !== undefined) {
      levelIndicator.textContent = `Level ${event.detail.level}`;
      levelIndicator.classList.add('level-changed');
      setTimeout(() => levelIndicator.classList.remove('level-changed'), 2000);
    }
  });
</script>