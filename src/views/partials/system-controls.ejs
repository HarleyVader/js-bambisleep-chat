<!DOCTYPE html>
<html lang="en">
<%- include('../views/partials/head.ejs') %>
    <title>BambiSleep.Chat AIGF</title>
    <style>
        /* Force system controls visibility */
        .system-controls-container {
            display: block !important;
            visibility: visible !important;
            min-height: 150px !important;
            opacity: 1 !important;
            margin-top: 20px;
            border: 1px solid rgba(255, 0, 128, 0.5);
        }

        .system-controls {
            display: block !important;
            visibility: visible !important;
        }

        .xp-progress-container {
            display: flex !important;
            visibility: visible !important;
            min-height: 30px;
            margin-top: 10px;
        }

        /* Ensure control panels are visible */
        #console,
        #buttons {
            display: block !important;
            min-height: 40px;
        }

        /* Diagnostic outline to see what's where */
        #console {
            border: 1px dashed rgba(0, 255, 255, 0.3);
        }

        #buttons {
            border: 1px dashed rgba(255, 0, 255, 0.3);
        }
    </style>

    <body data-username="<%= locals.username || '' %>">
        <%- include('../views/partials/nav.ejs') %>
            <div id="chat-container">
                <!-- Add modal for username prompt -->
                <div id="username-modal" class="modal">
                    <div class="modal-content">
                        <p>give me your bambi name:</p>
                        <input type="text" id="username-input" placeholder="Enter username">
                        <button id="username-submit">Submit</button>
                    </div>
                </div>
                <div id="user-input">
                    <h1>BambiSleep AIGF 👁️</h1>
                    <div id="llm">
                        <form id="llm-form">
                        </form>
                        <div id="user-prompt"></div>
                        <div id="audiomessage">
                        </div>
                    </div>
                    <br>
                    <div id="system-control-panel" class="system-controls">
                        <!-- XP Progress -->
                        <div class="xp-progress-container">
                            <div class="xp-progress">
                                <div class="xp-bar"></div>
                                <div class="xp-text">Level <span class="user-level">0</span> - <span
                                        class="xp-current">0</span>/<span class="xp-needed">0</span> XP</div>
                            </div>
                        </div>

                        <!-- Control Panels -->
                        <div id="control-tabs">
                            <div class="tab-nav">
                                <button class="tab-btn active" data-tab="trigger-controls">Triggers</button>
                                <button class="tab-btn" data-tab="collar-controls">Collar</button>
                                <button class="tab-btn" data-tab="spiral-controls">Spiral</button>
                                <button class="tab-btn" data-tab="audio-controls">Audio</button>
                                <button class="tab-btn" data-tab="mood-controls">Mood</button>
                            </div>

                            <!-- Trigger Controls -->
                            <div id="trigger-controls" class="tab-content active">
                                <div class="trigger-categories"></div>
                                <div class="active-triggers"></div>
                            </div>

                            <!-- Collar Controls -->
                            <div id="collar-controls" class="tab-content">
                                <div class="collar-toggle">
                                    <label>
                                        <input type="checkbox" id="collar-enabled" class="system-toggle">
                                        <span>Enable Collar</span>
                                    </label>
                                </div>
                                <div class="collar-settings">
                                    <div class="slider-container">
                                        <label for="collar-intensity">Intensity</label>
                                        <input type="range" id="collar-intensity" min="1" max="10" value="5"
                                            class="system-slider">
                                        <span class="slider-value">5</span>
                                    </div>
                                    <div class="collar-text">
                                        <label for="collar-text">Collar Text</label>
                                        <textarea id="collar-text-input"></textarea>
                                    </div>
                                </div>
                            </div>

                            <!-- Spiral Controls -->
                            <div id="spiral-controls" class="tab-content">
                                <div class="spiral-toggle">
                                    <label>
                                        <input type="checkbox" id="spiral-enabled" class="system-toggle">
                                        <span>Enable Spiral</span>
                                    </label>
                                </div>
                                <div class="spiral-settings">
                                    <div class="slider-container">
                                        <label for="spiral-speed">Speed</label>
                                        <input type="range" id="spiral-speed" min="1" max="10" value="5"
                                            class="system-slider">
                                        <span class="slider-value">5</span>
                                    </div>
                                    <div class="slider-container">
                                        <label for="spiral-opacity">Opacity</label>
                                        <input type="range" id="spiral-opacity" min="0" max="100" value="50"
                                            class="system-slider">
                                        <span class="slider-value">50%</span>
                                    </div>
                                </div>
                            </div>

                            <!-- Audio Controls -->
                            <div id="audio-controls" class="tab-content">
                                <div class="audio-toggle">
                                    <label>
                                        <input type="checkbox" id="audio-enabled" class="system-toggle">
                                        <span>Enable Audio Effects</span>
                                    </label>
                                </div>
                                <div class="audio-visualization-container"></div>
                                <div class="audio-settings">
                                    <div class="slider-container">
                                        <label for="audio-volume">Volume</label>
                                        <input type="range" id="audio-volume" min="0" max="100" value="75"
                                            class="system-slider">
                                        <span class="slider-value">75%</span>
                                    </div>
                                    <div class="binaural-settings">
                                        <label>
                                            <input type="checkbox" id="binaural-enabled" class="system-toggle">
                                            <span>Enable Binaural Beats</span>
                                        </label>
                                        <div class="slider-container">
                                            <label for="binaural-frequency">Frequency</label>
                                            <input type="range" id="binaural-frequency" min="1" max="40" value="7"
                                                class="system-slider">
                                            <span class="slider-value">7 Hz</span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Mood Controls -->
                            <div id="mood-controls" class="tab-content">
                                <div class="mood-selector">
                                    <label>Select Mood:</label>
                                    <div class="mood-buttons">
                                        <button data-mood="calm" class="mood-btn">Calm</button>
                                        <button data-mood="trance" class="mood-btn">Trance</button>
                                        <button data-mood="submissive" class="mood-btn">Submissive</button>
                                        <button data-mood="playful" class="mood-btn">Playful</button>
                                        <button data-mood="bambi" class="mood-btn">Bambi</button>
                                    </div>
                                </div>
                                <div class="current-mood">
                                    Current mood: <span id="current-mood-display">None</span>
                                </div>
                            </div>
                        </div>

                        <!-- Session Controls -->
                        <div id="session-controls">
                            <div class="session-buttons">
                                <button id="save-session-btn">Save Session</button>
                                <button id="load-session-btn">Load Session</button>
                                <button id="new-session-btn">New Session</button>
                            </div>
                            <div id="sessions-list-container" style="display: none;">
                                <select id="sessions-list"></select>
                                <button id="delete-session-btn">Delete</button>
                                <button id="load-selected-session-btn">Load</button>
                                <button id="cancel-session-list-btn">Cancel</button>
                            </div>
                        </div>
                    </div>
                </div>
                <div id="response-container">
                    <div id="response-chat-wrapper">
                        <div id="response"></div>
                        <div id="chat">
                        </div>
                    </div>
                    <div id="eyeCursorContainer">
                        <div id="eyeCursor">
                        </div>
                    </div>
                </div>
                <div id="collar-container" style="display: none;">
                    <div id="textarea-collar-response"></div>
                </div>
            </div>
            <%- include('../views/partials/footer.ejs') %>

                <script src="js/aigf-core.js"></script>
                <script src="js/psychodelic-trigger-mania.js"></script>
                <script src="js/text2speech.js"></script>
                <script src="js/responsive.js"></script>

                <script>
                    document.addEventListener("DOMContentLoaded", () => {
                        // Initialize system controls
                        initializeSystemControls();

                        // Check for username and handle modal display
                        function handleUsernameCheck() {
                            // Your existing code
                        }

                        // Give a short delay to ensure cookieUtils is loaded
                        setTimeout(handleUsernameCheck, 100);

                        // Set up chat form submission
                        document.getElementById("chat-form").addEventListener("submit", (event) => {
                            // Your existing code
                        });

                        // Handle chat messages
                        if (window.socket) {
                            // Your existing code
                        }
                    });

                    // Initialize system controls
                    function initializeSystemControls() {
                        // Get user level from body data attribute or from system state
                        let userLevel = 0;
                        if (window.bambiSystem) {
                            userLevel = window.bambiSystem.getUserLevel();
                        } else {
                            const body = document.querySelector('body');
                            userLevel = parseInt(body.getAttribute('data-user-level') || '0', 10);
                        }

                        // Update user level in the UI
                        document.querySelector('.user-level').textContent = userLevel;

                        // Set up tab navigation
                        setupTabNavigation();

                        // Update feature visibility based on user level
                        updateFeatureVisibility(userLevel);

                        // Initialize UI components
                        if (window.systemControlUI && typeof window.systemControlUI.init === 'function') {
                            window.systemControlUI.init();
                        }

                        // Initialize all control modules
                        if (window.bambiSystem && typeof window.bambiSystem.initializeModules === 'function') {
                            window.bambiSystem.initializeModules();
                        }
                    }

                    // Set up tab navigation for control panels
                    function setupTabNavigation() {
                        const tabButtons = document.querySelectorAll('.tab-btn');
                        const tabContents = document.querySelectorAll('.tab-content');

                        tabButtons.forEach(button => {
                            button.addEventListener('click', () => {
                                // Remove active class from all buttons and contents
                                tabButtons.forEach(btn => btn.classList.remove('active'));
                                tabContents.forEach(content => content.classList.remove('active'));

                                // Add active class to clicked button and corresponding content
                                button.classList.add('active');
                                const tabId = button.getAttribute('data-tab');
                                document.getElementById(tabId).classList.add('active');
                            });
                        });
                    }

                    // Update feature visibility based on user level
                    function updateFeatureVisibility(userLevel) {
                        if (!window.FEATURE_LEVELS) return;

                        // Hide features that are above the user's level
                        Object.entries(window.FEATURE_LEVELS).forEach(([feature, level]) => {
                            const elements = document.querySelectorAll(`.${feature}-controls, #${feature}-controls`);
                            elements.forEach(element => {
                                if (userLevel >= level) {
                                    element.classList.remove('locked-feature');
                                } else {
                                    element.classList.add('locked-feature');
                                }
                            });
                        });

                        // Update tab buttons visibility
                        document.querySelectorAll('.tab-btn').forEach(button => {
                            const tabId = button.getAttribute('data-tab');
                            const tabContent = document.getElementById(tabId);
                            if (tabContent && tabContent.classList.contains('locked-feature')) {
                                button.classList.add('locked-tab');
                            } else {
                                button.classList.remove('locked-tab');
                            }
                        });
                    }
                </script>

                <script>
                    // Your existing scripts
                </script>

                <!-- Control Scripts -->
                <script src="js/controls/system-controls.js"></script>
                <script src="js/controls/system-control-ui.js"></script>
                <script src="js/controls/trigger-controls.js"></script>
                <script src="js/controls/collar-controls.js"></script>
                <script src="js/controls/spiral-controls.js"></script>
                <script src="js/controls/mood-controls.js"></script>
                <script src="js/controls/audio-controls.js"></script>
                <script src="js/controls/audio-visualization.js"></script>
                <script src="js/controls/xp-system.js"></script>
                <script src="js/controls/xp-notification.js"></script>

                <!-- Add CSS for the control panels -->
                <style>
                    /* Tab Navigation */
                    .tab-nav {
                        display: flex;
                        flex-wrap: wrap;
                        margin-bottom: 10px;
                    }

                    .tab-btn {
                        padding: 8px 15px;
                        background: rgba(255, 0, 128, 0.2);
                        border: 1px solid rgba(255, 0, 128, 0.5);
                        color: #fff;
                        cursor: pointer;
                        margin-right: 5px;
                        margin-bottom: 5px;
                        transition: all 0.2s ease;
                    }

                    .tab-btn.active {
                        background: rgba(255, 0, 128, 0.5);
                        border-color: rgba(255, 0, 128, 0.8);
                    }

                    .tab-btn.locked-tab {
                        opacity: 0.5;
                        cursor: not-allowed;
                    }

                    .tab-content {
                        display: none;
                        padding: 15px;
                        border: 1px solid rgba(255, 0, 128, 0.3);
                        background: rgba(0, 0, 0, 0.2);
                    }

                    .tab-content.active {
                        display: block;
                    }

                    /* Sliders and Toggles */
                    .slider-container {
                        margin-bottom: 15px;
                    }

                    .system-slider {
                        width: 100%;
                        margin: 8px 0;
                    }

                    .slider-value {
                        display: inline-block;
                        min-width: 40px;
                        text-align: right;
                    }

                    /* XP Progress Bar */
                    .xp-progress-container {
                        margin-bottom: 20px;
                    }

                    .xp-progress {
                        height: 24px;
                        background: rgba(0, 0, 0, 0.3);
                        border: 1px solid rgba(255, 0, 128, 0.5);
                        position: relative;
                        border-radius: 3px;
                        overflow: hidden;
                    }

                    .xp-bar {
                        height: 100%;
                        background: linear-gradient(to right, rgba(255, 0, 255, 0.5), rgba(255, 0, 128, 0.7));
                        width: 0%;
                        transition: width 0.5s ease;
                    }

                    .xp-text {
                        position: absolute;
                        top: 50%;
                        left: 50%;
                        transform: translate(-50%, -50%);
                        color: white;
                        text-shadow: 1px 1px 1px rgba(0, 0, 0, 0.8);
                        font-weight: bold;
                    }

                    /* Locked Features */
                    .locked-feature {
                        position: relative;
                    }

                    .locked-feature::after {
                        content: "🔒 Level Up Required";
                        position: absolute;
                        top: 0;
                        left: 0;
                        right: 0;
                        bottom: 0;
                        background: rgba(0, 0, 0, 0.7);
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        color: #fff;
                        font-weight: bold;
                    }

                    /* Session Controls */
                    #session-controls {
                        margin-top: 20px;
                        padding-top: 15px;
                        border-top: 1px solid rgba(255, 0, 128, 0.3);
                    }

                    .session-buttons {
                        display: flex;
                        gap: 10px;
                        margin-bottom: 10px;
                    }

                    #sessions-list-container {
                        display: flex;
                        gap: 10px;
                        margin-top: 10px;
                    }

                    #sessions-list {
                        flex: 1;
                        background: rgba(0, 0, 0, 0.2);
                        color: white;
                        border: 1px solid rgba(255, 0, 128, 0.5);
                        padding: 5px;
                    }

                    /* Mood Controls */
                    .mood-buttons {
                        display: flex;
                        flex-wrap: wrap;
                        gap: 10px;
                        margin-top: 10px;
                    }

                    .mood-btn {
                        padding: 8px 15px;
                        background: rgba(0, 0, 0, 0.2);
                        border: 1px solid rgba(255, 0, 128, 0.5);
                        color: white;
                        cursor: pointer;
                        transition: all 0.2s ease;
                    }

                    .mood-btn.active {
                        background: rgba(255, 0, 128, 0.5);
                        border-color: rgba(255, 0, 128, 0.8);
                    }

                    .current-mood {
                        margin-top: 15px;
                        font-style: italic;
                    }

                    /* Audio Visualization */
                    .audio-visualization-container {
                        height: 80px;
                        background: rgba(0, 0, 0, 0.3);
                        border: 1px solid rgba(255, 0, 128, 0.3);
                        margin: 15px 0;
                    }

                    /* Trigger Controls */
                    .trigger-categories {
                        display: flex;
                        flex-wrap: wrap;
                        gap: 8px;
                        margin-bottom: 15px;
                    }

                    .trigger-category {
                        padding: 5px 10px;
                        background: rgba(0, 0, 0, 0.2);
                        border: 1px solid rgba(255, 0, 128, 0.5);
                        color: white;
                        cursor: pointer;
                    }

                    .trigger-category.active {
                        background: rgba(255, 0, 128, 0.5);
                    }

                    .active-triggers {
                        min-height: 50px;
                        padding: 10px;
                        background: rgba(0, 0, 0, 0.2);
                        border: 1px solid rgba(255, 0, 128, 0.3);
                    }

                    .trigger-tag {
                        display: inline-block;
                        padding: 3px 8px;
                        margin: 3px;
                        background: rgba(255, 0, 128, 0.3);
                        border-radius: 3px;
                    }

                    .trigger-tag .remove {
                        margin-left: 5px;
                        cursor: pointer;
                    }
                </style>
    </body>

</html>