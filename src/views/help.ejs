        <title>AIGF Help</title>
        <style>
            :root {
                --primary-color: #0c2a2ac9;
                --primary-alt: #15aab5ec;
                --secondary-color: #40002f;
                --secondary-alt: #005d46;
                --tertiary-color: #cc0174;
                --tertiary-alt: #01c69eae;
                --button-color: #df0471;
                --button-alt: #110000;
            }

            html,
            body {
                background-color: var(--button-alt);
                color: var(--primary-alt);
                font-family: "Audiowide", sans-serif;
                font-weight: 400;
                font-style: normal;
                margin: 0;
                padding: 0;
                scrollbar-width: thin;
                scrollbar-color: var(--primary-alt) var(--primary-color);
            }

            li {
                list-style-type: none;
                color: var(--tertiary-alt);
            }

            h1,
            h2,
            h3,
            h4,
            h5 {
                color: var(--button-color);
                margin-left: 0.3rem;
            }

            p {
                color: var(--primary-alt);
                margin-left: 2rem;
            }

            strong {
                color: var(--secondary-alt);
                margin-left: 1rem;
            }

            a {
                color: var(--tertiary-alt);
                text-decoration: underline;
            }

            a:hover {
                color: var(--secondary-alt);
            }

            #ascii-container {
                height: 220px;
                margin: 20px auto;
                max-width: 800px;
                border: 2px solid var(--tertiary-color);
                border-radius: 8px;
                background-color: rgba(0, 0, 0, 0.7);
            }

            .ascii-controls {
                text-align: center;
                margin: 10px auto;
                max-width: 800px;
            }

            .ascii-controls input[type="text"] {
                background-color: var(--button-alt);
                color: var(--primary-alt);
                border: 1px solid var(--tertiary-color);
                padding: 5px 10px;
                border-radius: 4px;
                margin-right: 10px;
            }

            .ascii-controls label {
                color: var(--tertiary-alt);
                margin: 0 10px;
            }
        </style>
</head>

