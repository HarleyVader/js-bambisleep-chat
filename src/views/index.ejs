<!DOCTYPE html>
<html lang="en">
<%- include('../views/partials/head.ejs') %>
  <title>BambiSleep.Chat AIGF</title>

  <body data-username="<%= locals.username || '' %>">
    <%- include('../views/partials/nav.ejs') %>
      <div id="chat-container">
        <!-- Add modal for username prompt -->
        <div id="username-modal" class="modal">
          <div class="modal-content">
            <p>give me your bambi name:</p>
            <input type="text" id="username-input" placeholder="Enter username">
            <button id="username-submit">Submit</button>
          </div>
        </div>
        <div id="user-input">
          <h1>BambiSleep AIGF 👁️</h1>
          <div id="llm">
            <form id="llm-form">
              <textarea id="textarea" oninput="autoExpand(this)" placeholder="Prompt my AIGF"></textarea>
              <button id="submit" type="submit" class="send-btn">Send</button>
            </form>
            <div id="user-prompt"></div>
            <div id="audiomessage">
              <audio id="audio" hidden controls></audio>
              <p id="message"></p>
              <p id="error-message" style="display: none; color: red;"></p>
            </div>
          </div>
          <br>
          <div id="system-controls-container" class="system-controls-container">
            <!-- System controls will be dynamically generated -->
          </div>
        </div>
        <div id="response-container">
          <div id="response-chat-wrapper">
            <div id="response"></div>
            <div id="chat">
              <form id="chat-form">
                <textarea id="textarea-chat" oninput="autoExpand(this)" placeholder="Send in Chat"></textarea>
                <button id="send" type="submit" class="send-btn">Chat</button>
              </form>
              <!-- For existing messages in the initial page load -->
              <ul id="chat-response">
                <% if (chatMessages && chatMessages.length> 0) { %>
                  <% chatMessages.forEach(function(msg) { %>
                    <li <% if (locals.username) { %>class="neon-glow"<% } %>>
                        <span class="chat-time">
                          <%= new Date(msg.timestamp).toLocaleTimeString([], {hour12: false}) %>
                        </span> -
                        <span class="chat-username"><a href="/profile/<%= msg.username %>" class="username-link">
                            <%= msg.username %>
                          </a>:</span>
                        <span class="chat-message">
                          <%= msg.data %>
                        </span>
                    </li>
                    <% }); %>
                      <% } %>
              </ul>
            </div>
          </div>
          <div id="eyeCursorContainer">
            <div id="eyeCursor">
              <div id="eyeCursorText"></div>
              <div id="eyeCursorText2"></div>
              <div id="eye" aria-label="Eye Cursor"></div>
              <div id="eyeCursorText3"></div>
              <div id="eyeCursorText4"></div>
            </div>
          </div>
        </div>
        <div id="collar-container" style="display: none;">
          <div id="textarea-collar-response"></div>
        </div>
      </div>
      <%- include('../views/partials/footer.ejs') %>

        <script src="js/aigf-core.js"></script>
        <script src="js/psychodelic-trigger-mania.js"></script>
        <script src="js/text2speech.js"></script>
        <script src="js/responsive.js"></script>

        <script>
          document.addEventListener("DOMContentLoaded", () => {
            // Initialize system controls
            generateSystemControls();

            // Check for username and handle modal display
            function handleUsernameCheck() {
              try {
                const modal = document.getElementById('username-modal');
                if (!modal) return;
                
                // Get username from cookie utils or fallback
                let username = '';
                if (window.cookieUtils) {
                  username = window.cookieUtils.getBambiName();
                } else {
                  // Fallback if cookieUtils not available
                  const cookies = document.cookie.split(';').reduce((acc, cookie) => {
                    const [key, value] = cookie.trim().split('=');
                    acc[key] = value;
                    return acc;
                  }, {});
                  username = cookies.bambiname || '';
                }
                
                // Store username in window for global access
                window.username = username;
                
                // Show modal if username not set or is default
                if (!username || username === 'anonBambi') {
                  modal.style.display = 'block';
                } else {
                  // If username is set and not default, load profile
                  if (username !== 'anonBambi' && window.loadProfileTriggers) {
                    window.loadProfileTriggers(username);
                  }
                }
                
                // Update body attribute
                document.body.setAttribute('data-username', username || '');
                
                // Set up submit button handler
                const submitButton = document.getElementById('username-submit');
                if (submitButton) {
                  submitButton.addEventListener('click', () => {
                    const input = document.getElementById('username-input');
                    const newUsername = input.value.trim();
                    
                    if (newUsername) {
                      // Use cookieUtils if available, otherwise set directly
                      if (window.cookieUtils) {
                        window.cookieUtils.setBambiName(newUsername);
                      } else {
                        document.cookie = `bambiname=${encodeURIComponent(newUsername)}; path=/`;
                      }
                      
                      // Update global reference
                      window.username = newUsername;
                      
                      // Notify socket if connected
                      if (window.socket && window.socket.connected) {
                        window.socket.emit('set username', newUsername);
                      }
                      
                      // Hide modal
                      modal.style.display = 'none';
                      
                      // Reload to refresh everything with new username
                      window.location.reload();
                    }
                  });
                }
              } catch (error) {
                console.error('Error in username handling:', error);
              }
            }

            // Give a short delay to ensure cookieUtils is loaded
            setTimeout(handleUsernameCheck, 100);

            // Set up chat form submission
            document.getElementById("chat-form").addEventListener("submit", (event) => {
              event.preventDefault();
              const messageInput = document.getElementById("textarea-chat");
              const message = messageInput.value.trim();

              if (message && window.username) {
                if (window.socket && window.socket.connected) {
                  window.socket.emit("chat message", {
                    data: message,
                    username: window.username
                  });

                  messageInput.value = "";
                  messageInput.style.height = 'inherit';
                } else {
                  console.error("Socket connection not available");
                  alert("Not connected to chat server. Please refresh the page.");
                }
              }
            });

            // Handle chat messages
            if (window.socket) {
              window.socket.on("chat message", function (msg) {
                // Create new chat message element
                const item = document.createElement("li");

                const timeSpan = document.createElement("span");
                timeSpan.className = "chat-time";
                timeSpan.textContent = new Date(msg.timestamp).toLocaleTimeString([], { hour12: false });

                const usernameSpan = document.createElement("span");
                usernameSpan.className = "chat-username";

                const usernameLink = document.createElement("a");
                usernameLink.href = `/profile/${msg.username}`;
                usernameLink.className = "username-link";
                usernameLink.textContent = msg.username;

                usernameSpan.appendChild(usernameLink);

                const messageSpan = document.createElement("span");
                messageSpan.className = "chat-message";
                messageSpan.textContent = msg.data;

                item.appendChild(timeSpan);
                item.appendChild(document.createTextNode(" - "));
                item.appendChild(usernameSpan);
                item.appendChild(document.createTextNode(": "));
                item.appendChild(messageSpan);

                if (window.username) {
                  item.classList.add("neon-glow");
                }

                const chatList = document.getElementById("chat-response");
                chatList.appendChild(item);
                chatList.scrollTop = chatList.scrollHeight;
              });
            }
          });

          // Generate system controls dynamically
          function generateSystemControls() {
            const container = document.getElementById('system-controls-container');
            if (!container) return;

            // Get user level from body data attribute or from system state
            let userLevel = 0;
            if (window.bambiSystem) {
              userLevel = window.bambiSystem.getUserLevel();
            } else {
              userLevel = parseInt(document.body.getAttribute('data-level') || '0');
            }

            // Create control structure
            const structure = `
              <div class="system-controls" data-user-level="${userLevel}">
                <!-- Control buttons section -->
                <div id="buttons" class="control-buttons">
                  <!-- System control buttons will be added here -->
                </div>
                
                <!-- Control panels section -->
                <div id="console" class="control-panels">
                  <!-- System control panels will be added here -->
                </div>
                
                <!-- XP progress bar -->
                <div class="xp-progress-container">
                  <div class="xp-level-badge">
                    <span id="level-indicator">Level ${userLevel}</span>
                  </div>
                  <div class="xp-progress-label" id="xp-progress-label">
                    Loading XP...
                  </div>
                  <div class="xp-progress-bar">
                    <div class="xp-progress-fill" id="xp-progress-fill" style="width: 0%"></div>
                  </div>
                </div>
              </div>
            `;

            container.innerHTML = structure;

            // After DOM is updated, initialize the controls
            setTimeout(() => {
              if (window.bambiSystem) {
                // This will trigger all the controls to initialize
                document.dispatchEvent(new CustomEvent('system-initialized'));
              }
            }, 100);
          }
        </script>
        <script>
          // Monitor connection status
          (function () {
            let connectionMonitor = null;

            function startConnectionMonitoring() {
              if (connectionMonitor) clearInterval(connectionMonitor);

              connectionMonitor = setInterval(() => {
                if (window.socket) {
                  if (!window.socket.connected) {
                    console.warn('Socket disconnected - attempting to reconnect');
                    if (window.socketHandler && typeof window.socketHandler.reconnect === 'function') {
                      window.socketHandler.reconnect();
                    }
                  }
                } else {
                  console.error('Socket not initialized');
                  if (window.socketHandler && typeof window.socketHandler.init === 'function') {
                    window.socketHandler.init();
                  }
                }
              }, 30000); // Check every 30 seconds
            }

            // Start monitoring once page is fully loaded
            window.addEventListener('load', () => {
              setTimeout(startConnectionMonitoring, 2000);
            });

            // Store function to expose for manual checks
            window.checkConnection = function () {
              if (window.socket && window.socket.connected) {
                console.log('Socket connection is active');
                return true;
              } else {
                console.warn('Socket connection is inactive');
                if (window.socketHandler && typeof window.socketHandler.reconnect === 'function') {
                  window.socketHandler.reconnect();
                }
                return false;
              }
            };
          })();
        </script>
        <script>
          document.addEventListener('DOMContentLoaded', function() {
            // Initial creation of control panel
            if (window.systemControlUI && typeof window.systemControlUI.createControlPanel === 'function') {
              window.systemControlUI.createControlPanel();
            }
            
            // Initialize the UI module
            if (window.systemControlUI && typeof window.systemControlUI.init === 'function') {
              window.systemControlUI.init();
            }
            
            // Ensure controls are visible after a short delay to allow other modules to initialize
            setTimeout(function() {
              if (window.systemControlUI && typeof window.systemControlUI.ensureControlsVisibility === 'function') {
                window.systemControlUI.ensureControlsVisibility();
              }
            }, 500);
          });
        </script>
        <script>
          window.bambiSessions = (function() {
            // Private variables
            let currentSessionId = null;
            let isSessionDirty = false;
            let sessionMessages = [];
            
            // Initialize module
            function init() {
              try {
                // Set up event listeners
                setupEventListeners();
                
                console.log('Session manager initialized');
              } catch (error) {
                console.error('Error initializing session manager:', error);
              }
            }
            
            // Set up event listeners
            function setupEventListeners() {
              if (window.socket) {
                // Session events from server
                window.socket.on('session-loaded', handleSessionLoaded);
                window.socket.on('session-saved', handleSessionSaved);
                window.socket.on('session-created', handleSessionCreated);
                window.socket.on('session-deleted', handleSessionDeleted);
                window.socket.on('session-error', handleSessionError);
                window.socket.on('sessions-list', handleSessionsList);
                
                // Socket lifecycle events
                window.socket.on('connect', handleConnect);
                window.socket.on('disconnect', handleDisconnect);
              }
              
              // Listen for system updates that should be saved
              document.addEventListener('trigger-state-changed', markSessionDirty);
              document.addEventListener('collar-update', markSessionDirty);
              document.addEventListener('spiral-update', markSessionDirty);
            }
            
            // Mark session as needing to be saved
            function markSessionDirty() {
              isSessionDirty = true;
              
              // Add visual indicator if session has unsaved changes
              const saveIndicator = document.getElementById('session-save-indicator');
              if (saveIndicator) {
                saveIndicator.classList.add('unsaved');
                saveIndicator.textContent = 'Unsaved changes';
              }
            }
            
            // Load a session
            function loadSession(sessionId) {
              if (!sessionId || !window.socket) return;
              
              try {
                // Show loading indicator
                const container = document.getElementById('system-controls-container');
                if (container) container.classList.add('loading');
                
                // Send load request
                window.socket.emit('load-session', sessionId);
              } catch (error) {
                console.error('Error loading session:', error);
                
                // Remove loading indicator
                const container = document.getElementById('system-controls-container');
                if (container) container.classList.remove('loading');
              }
            }
            
            // Save current session
            function saveSession(options = {}) {
              if (!window.socket || !window.username || window.username === 'anonBambi') {
                showSessionError('You must set a BambiName to save sessions');
                return;
              }
              
              try {
                // Collect settings from central state manager
                const settings = collectSettings();
                
                // Get recent messages if needed
                const messageCount = options.messageCount || 50;
                const messages = getRecentMessages(messageCount);
                
                // Create session data object
                const sessionData = {
                  sessionId: currentSessionId,
                  title: options.title || `Session ${new Date().toLocaleString()}`,
                  settings: settings,
                  messages: messages
                };
                
                // Send save request
                window.socket.emit('save-session', sessionData);
                
                // Reset dirty flag
                isSessionDirty = false;
                
                // Update UI
                const saveIndicator = document.getElementById('session-save-indicator');
                if (saveIndicator) {
                  saveIndicator.classList.remove('unsaved');
                  saveIndicator.textContent = 'Saving...';
                }
              } catch (error) {
                console.error('Error saving session:', error);
                showSessionError('Error saving session');
              }
            }
            
            // Handle session loaded event
            function handleSessionLoaded(data) {
              try {
                if (!data || !data.session) return;
                
                // Store current session ID
                currentSessionId = data.sessionId;
                
                // Apply session settings
                if (window.bambiSystem) {
                  window.bambiSystem.applySessionSettings({
                    activeTriggers: data.session.metadata?.triggers || [],
                    collarSettings: {
                      enabled: data.session.metadata?.collarActive || false,
                      text: data.session.metadata?.collarText || ''
                    },
                    spiralSettings: data.session.metadata?.spiralSettings || {}
                  });
                }
                
                // Dispatch event for other components
                document.dispatchEvent(new CustomEvent('session-loaded', {
                  detail: { session: data.session }
                }));
                
                // Reset dirty flag
                isSessionDirty = false;
                
                // Remove loading indicator
                const container = document.getElementById('system-controls-container');
                if (container) container.classList.remove('loading');
                
                // Update active session indicator
                updateActiveSessionIndicator(data.session.title);
              } catch (error) {
                console.error('Error handling loaded session:', error);
                
                // Remove loading indicator
                const container = document.getElementById('system-controls-container');
                if (container) container.classList.remove('loading');
              }
            }
            
            // Other handler functions and utilities...
            
            // Collect settings from all system components
            function collectSettings() {
              // Try to use central state management first
              if (window.bambiSystem && typeof window.bambiSystem.collectSettings === 'function') {
                return window.bambiSystem.collectSettings();
              }
              
              // Fallback to direct collection
              return {
                activeTriggers: getActiveTriggers(),
                collarSettings: getCollarSettings(),
                spiralSettings: getSpiralSettings()
              };
            }
            
            // Public API
            return {
              init,
              loadSession,
              saveSession,
              deleteSession,
              getSessionsList,
              getCurrentSessionId: () => currentSessionId,
              isSessionDirty: () => isSessionDirty,
              collectSettings
            };
          })();

          // Initialize on page load
          document.addEventListener('DOMContentLoaded', function() {
            if (window.bambiSessions) {
              window.bambiSessions.init();
            }
          });
        </script>
        <script src="https://ajax.googleapis.com/ajax/libs/jquery/1.12.4/jquery.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/p5@1.4.0/lib/p5.js"></script>
        <script src="js/bootstrap.min.js"></script>
  </body>

</html>